# BizObs Generator Environment Configuration

# Server Configuration
PORT=8080
NODE_ENV=production

# Service Port Range (for dynamic step services)
SERVICE_PORT_MIN=8081
SERVICE_PORT_MAX=8120

# Dynatrace Configuration
# Get these from your Dynatrace environment
DT_ENVIRONMENT=https://YOUR_TENANT.apps.dynatrace.com
DT_PLATFORM_TOKEN=dt0s16.SAMPLE.YOUR_TOKEN_HERE

# Dynatrace Application Metadata
DT_APPLICATION=BizObs-CustomerJourney
DT_SERVICE_NAME=BizObs-MainServer
DT_OWNER=ace-box-demo
DT_RELEASE_STAGE=production
DT_CUSTOMER_ID=dynatrace-demo

# Dynatrace Grail Query Budget (in GB)
DT_GRAIL_QUERY_BUDGET_GB=100

# Optional: OAuth Configuration (alternative to Platform Token)
# OAUTH_CLIENT_ID=dt0s02.SAMPLE.YOUR_CLIENT_ID
# OAUTH_CLIENT_SECRET=dt0s02.SAMPLE.YOUR_CLIENT_SECRET
# DT_SSO_URL=https://sso.dynatrace.com

# Optional: Slack Integration
# SLACK_CONNECTION_ID=your_slack_connection_id

# Optional: Proxy Configuration
# HTTPS_PROXY=http://proxy.company.com:8080
# HTTP_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1,.company.local

# ==================================================
# Option 2 (No Power Automate Premium HTTP actions)
# Forms -> SharePoint List (standard connectors) -> Worker
# ==================================================
# Microsoft Graph app credentials (to read/update SharePoint list rows)
# MS_TENANT_ID=<aad-tenant-id>
# MS_CLIENT_ID=<app-registration-client-id>
# MS_CLIENT_SECRET=<app-registration-client-secret>
# SP_SITE_ID=<sharepoint-site-id>
# SP_LIST_ID=<sharepoint-list-id>
#
# Dynatrace account OAuth (for user/group provisioning)
# DT_ACCOUNT_ID=8840f9ea-5897-4bfe-8d39-683091252eec
# DT_ACCOUNT_OAUTH_CLIENT_ID=dt0s02.xxxxx
# DT_ACCOUNT_OAUTH_CLIENT_SECRET=xxxxxxxx
# DT_ACCOUNT_RESOURCE=urn:dtaccount:8840f9ea-5897-4bfe-8d39-683091252eec
# DT_ACCESS_GROUP_UUID=c92d03e6-3197-4c22-b031-31b4aa7a8d14
#
# SharePoint field names (internal names in your list)
# SP_EMAIL_FIELD=Email
# SP_STATUS_FIELD=Status
# SP_STATUS_PENDING=Pending
# SP_STATUS_PROCESSED=Processed
# SP_STATUS_FAILED=Failed
# SP_NOTES_FIELD=Notes
# SP_UPDATED_AT_FIELD=UpdatedAt
#
# Worker behavior
# ACCESS_WORKER_POLL_SECONDS=60
# ACCESS_WORKER_ONCE=false

# ============================================
# Required Platform Token Scopes:
# ============================================
# - app-engine:apps:run
# - storage:bizevents:read
# - storage:logs:read
# - storage:metrics:read
# - storage:events:read
# - storage:spans:read
