{
  "name": "BMW - Finance Application Flow",
  "content": {
    "tiles": {
      "0": {
        "type": "markdown",
        "content": "![](https://logo.clearbit.com/bmw.com)"
      },
      "1": {
        "type": "markdown",
        "content": "# BMW | Finance Application Flow Dashboard\n\nReal-time KPI monitoring..."
      },
      "2": {
        "type": "bubbleMap",
        "query": "fetch bizevents | filter json.companyName == $EventProvider | filter json.journeyType == $JourneyType | fields geo.location.latitude, geo.location.longitude, json.location, json.transactionValue",
        "visualizationSettings": {
          "bubbleMap": {
            "bubbleSizeField": "json.transactionValue",
            "locationField": "json.location",
            "latField": "geo.location.latitude",
            "lonField": "geo.location.longitude"
          }
        }
      },
      "3": {
        "type": "data",
        "query": "data record(section=\"Executive Summary\")",
        "visualization": "singleValue",
        "visualizationSettings": {
          "singleValue": {
            "colorThresholdTarget": "background",
            "colorRules": [
              {
                "color": "#1a5276",
                "condition": "default"
              }
            ]
          }
        }
      },
      "4": {
        "type": "data",
        "query": "fetch bizevents | filter json.companyName == $EventProvider | filter json.journeyType == $JourneyType | summarize conversionRate = sum(json.conversionRate) / count() * 100",
        "visualization": "singleValue",
        "visualizationSettings": {
          "singleValue": {
            "colorThresholdTarget": "background",
            "colorRules": [
              {
                "color": "#27ae60",
                "condition": "conversionRate >= 60"
              },
              {
                "color": "#f1c40f",
                "condition": "conversionRate >= 40 && conversionRate < 60"
              },
              {
                "color": "#e74c3c",
                "condition": "conversionRate < 40"
              }
            ],
            "unit": "%"
          }
        }
      },
