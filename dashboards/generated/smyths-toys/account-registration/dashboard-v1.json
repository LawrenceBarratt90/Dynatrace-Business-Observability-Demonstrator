    "variables": [
      {
        "name": "Event Provider",
        "key": "EventProvider",
        "type": "query",
        "multiple": false,
        "input": "data record(value = \"Smyths Toys\")",
        "defaultValue": "Smyths Toys"
      },
      {
        "type": "query",
        "name": "Region",
        "multiple": true,
        "query": "fetch bizevents | filter json.companyName == \"Smyths Toys\" | dedup json.region | fields json.region",
        "key": "Region",
        "input": "data record(value = \"All\")"
      },
      {
        "type": "query",
        "name": "Channel",
        "multiple": true,
        "query": "fetch bizevents | filter json.companyName == \"Smyths Toys\" | dedup json.channel | fields json.channel",
        "key": "Channel",
        "input": "data record(value = \"All\")"
      },
      {
        "type": "query",
        "name": "DeviceType",
        "multiple": true,
        "query": "fetch bizevents | filter json.companyName == \"Smyths Toys\" | dedup json.deviceType | fields json.deviceType",
        "key": "DeviceType",
        "input": "data record(value = \"All\")"
      },
      {
        "type": "query",
        "name": "UserSegment",
        "multiple": true,
        "query": "fetch bizevents | filter json.companyName == \"Smyths Toys\" | dedup json.userSegment | fields json.userSegment",
        "key": "UserSegment",
        "input": "data record(value = \"All\")"
      },
      {
        "type": "query",
        "name": "RegistrationStepName",
        "multiple": true,
        "query": "fetch bizevents | filter json.companyName == \"Smyths Toys\" | dedup json.registrationStepName | fields json.registrationStepName",
        "key": "RegistrationStepName",
        "input": "data record(value = \"All\")"
      },
      {
        "name": "Journey Type",
        "key": "JourneyType",
        "type": "query",
        "multiple": false,
        "input": "fetch bizevents | filter json.companyName == $EventProvider | fields json.journeyType | filter isNotNull(json.journeyType)| dedup json.journeyType",
        "defaultValue": "Account Registration"
      }
    ],
