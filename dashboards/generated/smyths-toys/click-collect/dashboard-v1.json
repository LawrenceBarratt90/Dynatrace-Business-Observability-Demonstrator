{
  "name": "Smyths Toys - Click & Collect",
  "content": {
    "tiles": {
      "0": {
        "type": "markdown",
        "content": "![](https://logo.clearbit.com/smythstoys.com)"
      },
      "1": {
        "type": "markdown",
        "content": "# Smyths Toys | Click & Collect Dashboard\n\nReal-time KPI monitoring..."
      },
      "2": {
        "type": "bubbleMap",
        "query": "fetch bizevents | filter json.companyName == $EventProvider | filter json.journeyType == $JourneyType | fields geo.location.latitude, geo.location.longitude, store_name, total_amount",
        "visualizationSettings": {
          "bubbleMap": {
            "bubbleSizeField": "total_amount",
            "bubbleLabelField": "store_name"
          }
        }
      },
      "3": {
        "type": "data",
        "query": "data record(section=\"Executive Summary\")",
        "visualization": "singleValue",
        "visualizationSettings": {
          "singleValue": {
            "colorThresholdTarget": "background",
            "colorRules": [
              {
                "color": "#1a5276",
                "condition": "true"
              }
            ]
          }
        }
      },
      "4": {
        "type": "data",
        "query": "fetch bizevents | filter json.companyName == $EventProvider | filter json.journeyType == $JourneyType | summarize revenue=sum(total_amount)",
        "visualization": "singleValue",
        "visualizationSettings": {
          "singleValue": {
            "colorThresholdTarget": "background",
            "colorRules": [
              {
                "color": "#1e8449",
                "condition": "revenue >= 100000"
              },
              {
                "color": "#f7b731",
                "condition": "revenue < 100000 && revenue >= 50000"
              },
              {
                "color": "#c0392b",
                "condition": "revenue < 50000"
              }
            ]
          }
        }
      },
      "5": {
        "type": "data",
        "query": "fetch bizevents | filter json.companyName == $EventProvider | filter json.journeyType == $JourneyType | summarize click_collect_orders=countIf(order_type==\"Click & Collect\")",
        "visualization": "singleValue",
        "visualizationSettings": {
          "singleValue": {
            "colorThresholdTarget": "background",
            "colorRules": [
              {
                "color": "#1e8449",
                "condition": "click_collect_orders >= 2000"
              },
              {
                "color": "#f7b731",
                "condition": "click_collect_orders < 2000 && click_collect_orders >= 1000"
              },
              {
                "color": "#c0392b",
                "condition": "click_collect_orders < 1000"
              }
            ]
          }
        }
      },
      "6": {
        "type": "data",
        "query": "fetch bizevents | filter json.companyName == $EventProvider | filter json.journeyType == $JourneyType | summarize avg_order_value=avg(total_amount)",
