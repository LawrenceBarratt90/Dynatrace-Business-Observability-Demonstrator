              {
                "color": "#f7b731",
                "condition": "avg_order_value < 60 && avg_order_value >= 40"
              },
              {
                "color": "#c0392b",
                "condition": "avg_order_value < 40"
              }
            ]
          }
        }
      },
      "7": {
