{
  "name": "@dynatrace/dql-kb-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Dynatrace DQL knowledge base with semantic search",
  "main": "dist/index.js",
  "bin": {
    "dql-kb-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "npm run build:index && npm run build:server",
    "build:index": "tsx scripts/build-index.ts",
    "build:server": "tsc",
    "dev": "npm run build && node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dynatrace",
    "dql",
    "knowledge-base",
    "semantic-search"
  ],
  "author": "Dynatrace",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
