{
  "name": "@devtools/kb-run",
  "version": "0.1.0",
  "description": "CLI tool for building AI agent packages from the knowledge base",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "kb-run": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs-extra'); fs.removeSync('dist/packages'); fs.copySync('packages', 'dist/packages');\"",
    "postbuild": "node -e \"try { require('fs').chmodSync('dist/index.js', '755') } catch(e) {}\"",
    "dev": "tsc --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "knowledge-base",
    "ai-agent",
    "devtools"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
